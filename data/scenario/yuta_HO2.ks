[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;18：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_14"  ]
[tb_ptext_show  x="7.000000298023224"  y="95"  size="32"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="部屋で宿題を片付けていたころ、端末にメッセージが届いた。どうせ澪がさっきの話で騒いでいるのだろうと端末に目をやると、その送り主は全く身に覚えのない人物からだった。&nbsp;そこには&nbsp;&nbsp;「Ｓは君たちを騙している。君だけがみんなを救うことができる。君はどうする？&nbsp;　念のため警告だ。22:00～23：00は警備員が巡回している。気を付けたまえ。」&nbsp;&nbsp;と書かれていた。一体誰が何の目的でこんなことを僕に送っているのか見当もつかない。&nbsp;しかし、どうも気になってしまった。“裏切者”という先生の言葉。そして、“騙している”というこのメッセージ。僕たちを取り巻く環境の中で何かが起きている。さすがの僕でも感じ取った。僕はこのメッセージの内容が気になり、宿題を進めることができなかった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*A"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*C"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
