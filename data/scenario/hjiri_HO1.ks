[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：55～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Hijiri_main_system.ks"  target="*聖会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_133"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="も一言も発さないまま教室にたどり着いた。&nbsp;澪「みんな！無事でよかった！」&nbsp;澪が目に涙を浮かべたまま大きな声で叫ぶ。&nbsp;「悠太は？」&nbsp;どうやら悠太だけがまだ来ていないようだった。もう一度２階に探しに行こうかと思っていると扉が開く。みんなが警戒し一瞬黙り、視線を向ける。その先には悠太が立っていた。&nbsp;悠太「みんなここにいたんだ。いろんな教室探し回ったのに誰も見つからないから心配したよ。しかも…。」&nbsp;そういい淀んでいる。もちろんその先は言わずともみんな分かっていた。中庭だ。&nbsp;「みんな、中庭は見たか？」&nbsp;オープニングに続く。"  edge="undefined"  shadow="undefined"  ]
