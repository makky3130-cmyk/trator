[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_102"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="ついに惚れ薬が完成した。しかし、この惚れ薬を入れる容器を失念していた。密閉性の薄いものや、誤飲の危険性のあるわかりづらい容器では、万が一が起きる可能性がある。それに、謎の薬品を持っていては明らかに不自然だ。そんな都合の良いものなんて。ある。この薬品の材料たちの入っていた容器だ。これなら薬品名は記載されているし、次の授業に使うかもしれなから予習ように先生から借りていたと言い訳が利く。僕はすぐに、「フェニルエチルアミン」と「オキシトシン」の容器に惚れ薬を入れ直し、厳重に密閉した。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="shin_HO1.ks"  size="20"  target="*L"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
