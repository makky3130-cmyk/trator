*C

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;20：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_22"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="いつも通りの時間に夕食へ向かう。会場へ着くとみんな既に集まっていた。話題はもちろんＨＲでの先生の謎の発言についてだった。僕はどうしても先生の言葉とメッセージの関連性がぬぐい切れず、みんなに提案した。&nbsp;「みんなで先生に、直接確かめに行かない？」&nbsp;僕が切り出さなくとも誰かがそのうち言っていたであろう提案をする。それが意外だったのか、聖はとても驚いた顔でこちらを見ていた。そしてもちろん健はのってきた。彼はこういう行事に目がない。少しでも面白そうならすぐに乗っかってくる。しかし問題は聖と詩織だろう。彼らは問題行動を嫌う側だ。無論僕も普段はそっち側なのだから文句は言えない。しかし、僕の考えは詩織の次の発言で簡単にひっくり返った。詩織が賛成したのだ。この流れにはさすがの聖も逆らえず、全員で夜の校舎に侵入することとなった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*B"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*D"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*D

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;21：30～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_30"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="話し合いの結果、慎の提案で“かくれんぼ”をすることになった。好都合だ。かくれんぼなら自然とみんな一人になる。みんなには申し訳ないが僕は一足先に執務室にお邪魔することにする。先生と二人きりでさっきのメッセージについても話がしたいのだ。みんなにはあとで謝ろう。そうして２階へ上がり、執務室へと向かう。２階に一緒に上がったのは慎と詩織だ。他の３人は１階に隠れることにしたようだ。慎は実験室に、詩織はPC室に入って行った。&nbsp;　僕はそのまま執務室に向かうわけにはいかないので、一度音楽室に隠れるふりをした。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*C"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*E"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*E

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;22：00～①"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_38"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="警備員が廊下を通りすぎる足音が聞こえる。どうやら１階から順に巡回するようだ。この機会を逃すわけにはいかない、僕はすぐに執務室へと向かった。&nbsp;　執務室に入ろうとしたとき、先生の声が聞こえ、扉越しに聞き耳を立てる。&nbsp;先生「計画は順調です。12人のSの育成は順調。残りの失敗作については殺処分で問題な&nbsp;いでしょう。卒業と同時にスクラップにします。それと一点ご報告が。被検体No．４、個体名河村健については少し疑念が残ります。スクラップの可能性があることはご承知おきください。」&nbsp;被検体？計画？スクラップ？殺、処分？何を言っているんだ？おかしい。だって先生はいつも優しくて、落ちこぼれだった僕に特に親切にしてくれた。何かの間違いだ。気が付くと僕は扉を開けて、先生に縋り付いていた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*D"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*F"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
