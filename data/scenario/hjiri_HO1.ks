[s  ]
*聖HO_1-P

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～②"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Hijiri_main_system.ks"  target="*聖会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_125"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="しかし、俺を見て少し落ち着いたのか、興奮しているようにも見える。&nbsp;慎「聖。澪を見なかったか？無事なのかな？」&nbsp;「澪ならＳ教室で隠れているよ。健も一緒のはずだ。慎もＳ教室に行こう。」&nbsp;俺は慎と共にみんなのいるＳ教室へと向かう。科学室の扉を開けると目の前を叫びながら通り過ぎていく詩織の姿があった。詩織は足を踏み外し、そのまま階段を転がり落ちていった。&nbsp;「詩織！大丈夫か？」&nbsp;詩織「聖君！慎！なんだ、びっくりした。」&nbsp;どうやら大きな怪我はないようだ。俺は慎と詩織と共に一度教室に戻ることにした。その途中どうしても視界に入ってしまう。中庭に落ちているものに。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="次のページ"  target="*聖HO_1-Q"  x="365"  y="21"  width=""  height=""  _clickable_img=""  ]
