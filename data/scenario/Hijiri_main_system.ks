[chara_show  name="聖"  time="1000"  wait="true"  storage="chara/7/聖　かんがえる_upscayl_4x_upscayl-standard-4x.png"  width="677"  height="1215"  left="308"  top="-33"  reflect="false"  ]
[mask_off  time="500"  effect="fadeOut"  ]
