[s  ]
*P

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～①"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_126"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="しばらく続いた静寂に、外の様子が無性に気になった私は、ＰＣ室から扉に耳を当て、外の様子を調べようとする。しかし、何も感じない。恐る恐るPC室の扉を開き、廊下に出る。&nbsp;そこには悠太が呆然と立ち尽くしていた。悠太はこちらに気づくと声をかけてきた。&nbsp;悠太「し、詩織。こっちに来てくれ。あれを見て。」&nbsp;悠太に言われるがまま悠太の視線の先、中庭を窓に手を当ててのぞき込む。そこには先ほど執務室に立っていた、先生を殺害した警備員が“落ちていた”。&nbsp;「い、いやあぁぁぁ。」&nbsp;私は叫びながら逃げ出す。一晩で２人も死んだ。それも、おそらくは他殺だ。私は恐怖のまま聖君を探す。彼ならこの状況でも道を示してくれるはず。私たちは聖君と一緒にいたくて集まっている集団なのだから、当然何かあれば全員、聖君を探すのだ。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="shiori_HO1.ks"  size="20"  target="*O"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="shiori_HO1.ks"  size="20"  target="*Q"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*Q

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～②"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_131"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="無我夢中で走り、実験室の前を通り過ぎるとき、実験室から誰かが出てきた。人影に驚き、階段を踏み外す。そして、そのまま転がり落ちた。幸いにも大けがはしなかったが体中に激痛が走る。階段の上から聖君の声が聞こえた。&nbsp;聖「詩織！大丈夫か！」&nbsp;「聖君！慎！なんだ、びっくりした。」&nbsp;聖君の顔を見てパニックが収まるのを感じる。慎のやつが一緒なのは気に食わないがひとまず聖君と合流できてよかった。そのまま３人でS教室へ向かった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="shiori_HO1.ks"  size="20"  target="*P"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="shiori_HO1.ks"  size="20"  target="*R"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*R

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：55～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_136"  ]
[tb_ptext_show  x="6.000000298023224"  y="94"  size="30"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="誰も一言も喋らずに、S教室にたどり着いた。扉を開けると涙目の澪とその横には健が座っていた。この光景はいつもの慎ならまた嫉妬に狂うのではないかと思ったが、澪の行動により、そんなことは起こらなかった。&nbsp;澪「みんな！無事でよかった！」&nbsp;涙目の澪が大きな声で言う。健は隣で何やらメンタルをやられているような顔をしているが、何か怖いものでも見たのだろうか？偏見だが、死体で健がメンタルをやられるとは思わない。何か裏がありそうだ。&nbsp;聖「悠太は？」&nbsp;慎が電気を点けると聖君が尋ねる？その直後、教室の扉が開き、悠太が入ってきた。&nbsp;悠太「なんだ。みんなここにいたんだ。いろんな教室探し回ったのにどこにもいないから心配したよ。しかも…。」&nbsp;普段は感情を表に出さない悠太も、流石に堪えたのか、言葉尻を言い淀む。しかし、&nbsp;聖「みんな。中庭は見たか？」&nbsp;聖君は悠太の言い淀んだことを代弁するように口にした。さすがの私にもわかる。この状況だ。警備員、そして先生を殺した犯人は私たち６人の中にいること。そして、聖君はその葉人を見つけたがっていることに。しかし、私はあまり犯人に興味はない。どちらかと言えば何かを隠していそうな慎や健の真意が知りたい。私は心の中で刺激を求め始めた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="shiori_HO1.ks"  size="20"  target="*Q"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
