[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_118"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="S教室に向かう途中詩織はずっと怯えた様子で中庭の反対側に一生懸命顔を向けていた。まるでそこには見たくないものがあるかのような様子だった。僕は気になってつい見てしまった。中庭には執務室で先生の死体の横に立ち尽くしていた警備員と思わしき人物が“落ちていた”。僕は叫びそうになりながら嗚咽を抑える。吐きそうな僕、心配そうに背中をさすってくれる聖と、同じ経験をしたのか詩織は同情の目でこちらを見つめていた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="shin_HO1.ks"  size="20"  target="*N"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
