[s  ]
*聖HO1-M

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Hijiri_main_system.ks"  target="*聖会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_101"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="何も起こらない状況に嫌気がさしたのか、それとも時間が経ち、少し落ち着いたのか、澪が言葉を放った。&nbsp;「みんなは、大丈夫なのかな？」&nbsp;そういえば人影は２階にいたはず。何人かは２階の教室に隠れていたはず。みんなは無事なのか？&nbsp;「俺は２階を探してくる。澪はここで待っていてくれ。」&nbsp;澪にそう伝えて俺は震える足を奮い立たせ、２階へと向かった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="次のページ"  target="*聖HO_1-N"  x="365"  y="21"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="前のページ"  target="*聖HO_1-L"  x="670"  y="21"  width=""  height=""  _clickable_img=""  ]
[s  ]
*聖HO_1-N

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：15～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Hijiri_main_system.ks"  target="*聖会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_109"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="２階への階段に差しかかったとき、健が１階の廊下にいることに気づいた。俺は健に駆け寄りすぐに声をかけた。&nbsp;健「おー！聖！なんだよ無事だったか。」&nbsp;健は今にも泣き出しそうな顔をしていた。今まで見たことのないその表情に俺はつられてしまいそうになる。しかし、そんな場合ではない。２階を確認しに行かなければ。&nbsp;「健。無事でよかった。澪がＳ教室にいる。俺は2階を確認しに行くから澪と一緒にいてあ&nbsp;げてくれ。」&nbsp;健「わかった。」"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="次のページ"  target="*聖HO_1-O"  x="365"  y="21"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="前のページ"  target="*聖HO1-M"  x="670"  y="21"  width=""  height=""  _clickable_img=""  ]
[s  ]
*聖HO_1-O

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～①"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Hijiri_main_system.ks"  target="*聖会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_117"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="健と別れ２階に上がると、そこは１階とは全く違う異様な空気感に包まれていた。違和感の正体の一つはすぐに分かった。臭いだ。甘ったるい香りと、血の匂いが混ざっている。俺は恐怖に身を包まれながらも教室を一つずつ確認することにした。&nbsp;　最も階段に近い実験室に入る。実験室からは微かに甘い香りが漂っていた。そして、扉を開けると、慎の叫び声が響く。&nbsp;慎「うわぁぁ。く、来るなー。」&nbsp;「慎！俺だ！落ちつけ。」&nbsp;慎「ひ、聖か。なんだ。警備員が殺しに来たのかと思ったよ。」&nbsp;慎はどうやらパニックになっていたようだ。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="hjiri_HO.ks"  size="20"  text="次のページ"  target="*聖HO_1-P"  x="365"  y="21"  width=""  height=""  _clickable_img=""  ]
