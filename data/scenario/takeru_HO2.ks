*健HO_1-P

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：55～②"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Takeru_main_system.ks"  target="*会議１中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_6"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="聖「悠太は？」&nbsp;聖が言葉を発したそのすぐ後に扉が開く。そして、悠太が入ってきた。&nbsp;悠太「みんなここにいたんだ。いろんな教室探し回ったのに誰も見つからないから心配したよ。しかも…。」&nbsp;そう言葉尻を言いよどむ。もちろん警備員の死体を目にしたのだろう。そういえば、&nbsp;警備員はどうして死んだんだろう？不注意で落ちることがないのは、普段俺らも生活しているので分かる。つまり、何らかの原因で落ちた、もしくは“落とされた”ということになる。&nbsp;聖「みんな、中庭は見たか？」&nbsp;聖が悠太の言いよどんだ部分を口にする。やっぱりこいつには敵わない。俺にできることは少しでも真実に近づけるようにすることだけだろう。"  edge="undefined"  shadow="undefined"  ]
