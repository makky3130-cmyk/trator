[tb_ptext_show  x="4.000000298023224"  y="94"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="通気口から体育館へと戻る。念のためほかに体育館に変なところがないか確認して回る。しかし、基本的に見えるところには異変は感じ取れなかった。もう少し詳しく調べたいが、一人でいるのに精神的に耐えられなくなってきた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-K"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
