[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Mio_main_system.ks"  target="*澪会議１最中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_110"  ]
[tb_ptext_show  x="9.000000298023224"  y="93"  size="33"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="容器を密閉し終えた瞬間、実験室の扉が開けられた。警備員が来たと驚いていた僕は、パニックになり、叫ぶ。&nbsp;「うわぁぁ。く、くるなー。」&nbsp;聖「慎。俺だ！落ち着け！」&nbsp;扉の先に立っていたのは聖だった。聖が迎えに来てくれたことに安堵し、少し落ち着いた僕だったが、そこには聖一人しかいないことに気づいた。澪は聖と一緒じゃないのか？無事なのか？&nbsp;「聖、澪を見なかった？無事なのかな？」&nbsp;聖「澪ならＳ教室で隠れているよ。健も一緒のはずだ。慎もＳ教室に行こう。」&nbsp;その言葉に安心したが、また健か。あいつはずっと澪にくっついていて目障りだ。いっそ死んでいてくれればよかったのに。そんなどす黒い感情を自然と抱いていることにも気づかず、聖に連れられ実験室を離れた。&nbsp;　扉から出ると、目の前を詩織がものすごいスピードで叫びながら走り抜けていった。そのまま階段を踏み外し、一階へとこ転がり落ちていった。&nbsp;聖「詩織！大丈夫か？」&nbsp;詩織「聖君！慎！なんだ、びっくりした。」&nbsp;どうやら大きな怪我はないようだ。僕と詩織は聖と共に一度教室に戻ることにした。"  edge="undefined"  shadow="undefined"  ]
