[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;16：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[tb_ptext_show  x="1.010416328907013"  y="169"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="裏切者？何のことかさっぱりわかんねー。先生は頭おかしくなっちまったのか？でも先生だしなー。何の根拠もないが先生に対する絶対的な信頼が俺にはある。だからきっと何か意味があるのだとそう思い、自分の部屋へと帰ることにした。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_１-B"  text="次のページ"  x="575"  y="12"  width=""  height=""  _clickable_img=""  ]
[s  ]
*健HO_１-B

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;18：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Takeru_main_system.ks"  target="*会議１中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_14"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="いつものように宿題を片付けているとき、携帯が震えた。澪あたりがどうせ騒いでいるのだろうと無視していたが、どうにも俺も話に参加したくなって通知を確認する。しかし、そこにあったのは全く身に覚えのないIDからのメッセージだった。「学校の七不思議。君の身に起きた摩訶不思議な出来事。その答えは体育館にある。興味があれば探してみると良い。幸運を祈っているよ。」と不気味なメッセージが書いていた。随分と上から目線なうえに、全てを見透かしたかのような文言が気に食わない。しかし、あの不思議な出来事を気になっていのもまた事実。どうにもぬぐい切れない気持ち悪さが残ってしまった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO１-A"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
