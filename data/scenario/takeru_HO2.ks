*健HO1-M

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：15～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Takeru_main_system.ks"  target="*会議１中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_6"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="体育館を出て、S教室のほうに向かう。歩いていた時、聖が駆け寄ってきた。&nbsp;「おー！聖！何だよ無事だったか。」&nbsp;俺は今にも泣き出しそうになりながら、親友の顔をみて安堵する。&nbsp;聖「健。無事でよかった。澪がＳ教室にいる。俺は2階を確認しに行くから澪と一緒にいてあげてくれ。」&nbsp;俺は聖と共にいたい気持ちを抑え、うなずく。俺の様子を見て、聖は心底信頼しきった目でほほ笑んだ。そのまま聖は２階へと向かって行った。親友の無事を祈り俺は急いでＳ教室へと向かって行った。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-L"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-N"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*健HO_1-N

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：30～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Takeru_main_system.ks"  target="*会議１中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_6"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="教室に入ると澪は何かを握りしめてぶつぶつとつぶやいていた。&nbsp;「澪？大丈夫か？」&nbsp;俺は心配になり声をかける。すると澪は慌てた様子で手に持っていた何かを懐に隠した。顔を上げた澪の目は期待に満ちていたが、すぐに元の無表情に戻った。どうやら澪の求める人は俺ではなかったようだ。これが聖ならやはり違ったのだろうか？それに、隠したものが気になったが尋ねられるような状況じゃなかった。俺は何もできない自分の無力さに心底呆れながら澪の隣に座る。そのまま長い沈黙が続いた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO1-M"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-O"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
[s  ]
*健HO_1-O

[tb_ptext_hide  time="0"  ]
[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;24：55～①"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[button  storage="Takeru_main_system.ks"  target="*会議１中"  graphic="×ボタン.png"  width="120"  height="120"  x="1159"  y="-10"  _clickable_img=""  name="img_6"  ]
[tb_ptext_show  x="12.010415375232697"  y="114"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="30分程度だろうか？その間一言も会話をすることはなかった。澪に話しかけようと口を開きかけ、何度も諦める。澪が求める言葉が何のか、俺にはわからないし、持ち合わせてもいないのだろうと。&nbsp;　突然扉が開く。そこにはさっき別れた親友と、慎、詩織の姿があった。&nbsp;澪「みんな！無事でよかった！」&nbsp;さっきまで一言も発さなかった澪のその言葉に俺は落胆する。俺がもし、聖だったら。そう思わずにはいられなかった。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-N"  text="前のページ"  x="460"  y="11"  width=""  height=""  _clickable_img=""  ]
[glink  color="black"  storage="takeru_HO1.ks"  size="20"  target="*健HO_1-P"  text="次のページ"  x="691"  y="11"  width=""  height=""  _clickable_img=""  ]
