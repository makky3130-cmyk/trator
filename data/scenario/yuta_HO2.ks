[tb_ptext_show  x="10.000005066394806"  y="15.000015258789062"  size="50"  color="0xffffff"  time="1000"  text="HO&nbsp;16：00～"  face="serif,'游明朝'"  anim="false"  edge="undefined"  shadow="undefined"  ]
[tb_ptext_show  x="7"  y="163"  size="35"  color="0xffffff"  time="1"  face="serif,'游明朝'"  anim="false"  text="唐突に先生が放った謎の一言に僕はただただ困惑した。僕は普通の子より比較的先生と仲が良いほうだ。しかし、先生が今まで意味のない言葉を口にするのを聞いたことがなかった。つまり先生のこの言葉には何か真意が隠されているはずだ。僕はこの言葉を忘れまいと胸に刻みこんだ。澪がいつものように騒ぎ出す。それに健が呼応する。この二人の息の合い方には前世が家族なのではないかと本気で思うほどには目を見張るものがある。いつもの流れで話題が広がっていく。もちろん先生の謎の言葉“裏切者”についてだ。&nbsp;　3人寄れば文殊の知恵、しかも今はその倍の６人もいる。しかし、答えは出なかった。謎の言葉の謎を残したまま僕は帰路へとついた。"  edge="undefined"  shadow="undefined"  ]
[glink  color="black"  storage="yuta_HO1.ks"  size="20"  target="*B"  text="次のページ"  x="575"  y="12"  width=""  height=""  _clickable_img=""  ]
[s  ]
*B

